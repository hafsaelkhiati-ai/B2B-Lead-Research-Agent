# ============================================================
#  B2B Lead Research Agent — Environment Variables
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to Git.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── OpenAI ─────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# ── HubSpot ────────────────────────────────────────────────
# Create a Private App at: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.companies.write
HUBSPOT_ACCESS_TOKEN=pat-REPLACE_WITH_YOUR_HUBSPOT_TOKEN

# ── Apollo.io ──────────────────────────────────────────────
# Get your key at: https://developer.apollo.io/
APOLLO_API_KEY=REPLACE_WITH_YOUR_APOLLO_KEY

# ── Clay ───────────────────────────────────────────────────
# Get your API key from: Clay → Settings → API
CLAY_API_KEY=REPLACE_WITH_YOUR_CLAY_KEY
# Your Clay table webhook URL (optional — for triggering Clay enrichment runs)
CLAY_WEBHOOK_URL=https://REPLACE_WITH_YOUR_CLAY_WEBHOOK_URL

# ── Slack (optional — for sales alerts) ───────────────────
# Create an Incoming Webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_SLACK_WEBHOOK

# ── ICP Default Config ─────────────────────────────────────
# Comma-separated — used if the frontend sends no custom config
ICP_INDUSTRIES=SaaS,Manufacturing,Chemical,Logistics
ICP_LOCATIONS=Germany,Austria,Switzerland
ICP_MIN_EMPLOYEES=50
ICP_MAX_EMPLOYEES=5000
